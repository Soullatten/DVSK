generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============ USERS ============

model User {
  id          String   @id @default(cuid())
  firebaseUid String   @unique
  email       String?  @unique
  phone       String?  @unique
  name        String?
  avatar      String?
  role        Role     @default(CUSTOMER)

  addresses Address[]
  cart      Cart?
  orders    Order[]
  reviews   Review[]
  wishlist  Wishlist?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([firebaseUid])
  @@index([email])
}

enum Role {
  CUSTOMER
  ADMIN
  SUPER_ADMIN
}

model Address {
  id           String  @id @default(cuid())
  userId       String
  user         User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  label        String  @default("Home")
  fullName     String
  phone        String
  addressLine1 String
  addressLine2 String?
  city         String
  state        String
  pincode      String
  country      String  @default("India")
  isDefault    Boolean @default(false)

  orders Order[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

// ============ PRODUCTS ============

model Category {
  id          String     @id @default(cuid())
  name        String     @unique
  slug        String     @unique
  description String?
  image       String?
  parentId    String?
  parent      Category?  @relation("SubCategories", fields: [parentId], references: [id])
  children    Category[] @relation("SubCategories")

  products Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Product {
  id          String  @id @default(cuid())
  name        String
  slug        String  @unique
  description String
  shortDesc   String?

  basePrice Decimal  @db.Decimal(10, 2)
  salePrice Decimal? @db.Decimal(10, 2)

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  tag    ProductTag @default(CORE)
  gender Gender

  images   ProductImage[]
  variants ProductVariant[]
  reviews  Review[]

  isActive   Boolean @default(true)
  isFeatured Boolean @default(false)

  cartItems     CartItem[]
  orderItems    OrderItem[]
  wishlistItems WishlistItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categoryId])
  @@index([slug])
  @@index([tag])
  @@index([gender])
  @@index([isActive, isFeatured])
}

enum ProductTag {
  NEW_SEASON
  CORE
  ESSENTIALS
  LIMITED_EDITION
  SALE
}

enum Gender {
  MEN
  WOMEN
  UNISEX
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String
  alt       String?
  position  Int     @default(0)

  @@index([productId])
}

model ProductVariant {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  size          String
  color         String
  colorHex      String?
  sku           String  @unique
  stock         Int     @default(0)
  reservedStock Int     @default(0)
  lowStockAlert Int     @default(5)
  priceOverride Decimal? @db.Decimal(10, 2)

  cartItems          CartItem[]
  orderItems         OrderItem[]
  purchaseOrderItems PurchaseOrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([productId, size, color])
  @@index([sku])
  @@index([stock])
}

// ============ CART ============

model Cart {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  items CartItem[]

  updatedAt DateTime @updatedAt
}

model CartItem {
  id     String @id @default(cuid())
  cartId String
  cart   Cart   @relation(fields: [cartId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id])
  variantId String
  variant   ProductVariant @relation(fields: [variantId], references: [id])

  quantity Int @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([cartId, variantId])
  @@index([cartId])
}

// ============ ORDERS ============

model Order {
  id          String @id @default(cuid())
  orderNumber String @unique

  userId    String
  user      User    @relation(fields: [userId], references: [id])
  addressId String
  address   Address @relation(fields: [addressId], references: [id])

  items   OrderItem[]
  payment Payment?

  subtotal     Decimal @db.Decimal(10, 2)
  shippingCost Decimal @db.Decimal(10, 2) @default(0)
  discount     Decimal @db.Decimal(10, 2) @default(0)
  tax          Decimal @db.Decimal(10, 2) @default(0)
  total        Decimal @db.Decimal(10, 2)

  couponCode String?
  status     OrderStatus @default(PENDING)

  notes      String?
  adminNotes String?

  shippingProvider String?
  trackingNumber   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([orderNumber])
  @@index([status])
  @@index([createdAt])
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
  RETURNED
  REFUNDED
}

model OrderItem {
  id      String @id @default(cuid())
  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id])
  variantId String
  variant   ProductVariant @relation(fields: [variantId], references: [id])

  quantity   Int
  unitPrice  Decimal @db.Decimal(10, 2)
  totalPrice Decimal @db.Decimal(10, 2)

  productName String
  size        String
  color       String
  image       String?

  @@index([orderId])
}

// ============ PAYMENTS ============

model Payment {
  id      String @id @default(cuid())
  orderId String @unique
  order   Order  @relation(fields: [orderId], references: [id])

  razorpayOrderId   String @unique
  razorpayPaymentId String?
  razorpaySignature String?

  amount   Decimal       @db.Decimal(10, 2)
  currency String        @default("INR")
  method   String?
  status   PaymentStatus @default(PENDING)

  refundId     String?
  refundAmount Decimal? @db.Decimal(10, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([razorpayOrderId])
  @@index([status])
}

enum PaymentStatus {
  PENDING
  AUTHORIZED
  CAPTURED
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

// ============ REVIEWS ============

model Review {
  id        String  @id @default(cuid())
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  rating     Int
  title      String?
  text       String
  isVerified Boolean @default(false)
  isApproved Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, productId])
  @@index([productId])
  @@index([rating])
}

// ============ WISHLIST ============

model Wishlist {
  id     String         @id @default(cuid())
  userId String         @unique
  user   User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  items  WishlistItem[]
}

model WishlistItem {
  id         String   @id @default(cuid())
  wishlistId String
  wishlist   Wishlist @relation(fields: [wishlistId], references: [id], onDelete: Cascade)
  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([wishlistId, productId])
  @@index([wishlistId])
}

// ============ COUPONS ============

model Coupon {
  id            String       @id @default(cuid())
  code          String       @unique
  description   String?
  discountType  DiscountType
  discountValue Decimal      @db.Decimal(10, 2)
  maxDiscount   Decimal?     @db.Decimal(10, 2)
  minOrderValue Decimal?     @db.Decimal(10, 2)
  usageLimit    Int?
  usedCount     Int          @default(0)
  perUserLimit  Int          @default(1)
  validFrom     DateTime
  validUntil    DateTime
  isActive      Boolean      @default(true)

  createdAt DateTime @default(now())

  @@index([code])
  @@index([isActive, validFrom, validUntil])
}

enum DiscountType {
  PERCENTAGE
  FLAT
}

// ============ PURCHASE ORDERS (inbound inventory) ============

model PurchaseOrder {
  id          String              @id @default(cuid())
  orderNumber String              @unique
  supplier    String
  city        String
  country     String
  amount      Decimal              @db.Decimal(12, 2)
  currency    String               @default("INR")
  itemsLabel  String
  status      PurchaseOrderStatus  @default(PROCESSING)
  progress    Int                  @default(15)
  eta         DateTime?
  lat         Float?
  lng         Float?
  notes       String?

  // ── Shipment details (set by admin from PurchaseOrders page) ──
  // carrier        — courier name (FedEx, DHL, BlueDart, Delhivery, …)
  // trackingNumber — courier-issued tracking ID
  // dispatchedAt   — when supplier handed the freight to the carrier
  // weight         — package weight in kg (free-form for unit flexibility)
  // shipmentNotes  — admin-only notes about the shipment itself
  carrier        String?
  trackingNumber String?
  dispatchedAt   DateTime?
  weight         String?
  shipmentNotes  String?

  lineItems   PurchaseOrderItem[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deliveredAt DateTime?

  @@index([status])
  @@index([orderNumber])
}

model PurchaseOrderItem {
  id              String        @id @default(cuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  variantId String
  variant   ProductVariant @relation(fields: [variantId], references: [id])

  quantity Int
  unitCost Decimal? @db.Decimal(10, 2)

  createdAt DateTime @default(now())

  @@index([purchaseOrderId])
  @@index([variantId])
}

enum PurchaseOrderStatus {
  PROCESSING
  IN_TRANSIT
  CUSTOMS
  DELIVERED
  CANCELLED
}

// ============ MARKETING & GROWTH ============

model Campaign {
  id          String         @id @default(cuid())
  name        String
  platform    String
  status      CampaignStatus @default(ACTIVE)
  spend       Decimal        @default(0) @db.Decimal(12, 2)
  revenue     Decimal        @default(0) @db.Decimal(12, 2)
  clicks      Int            @default(0)
  conversions Int            @default(0)
  startDate   DateTime?
  endDate     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
}

enum CampaignStatus {
  ACTIVE
  PAUSED
  DRAFT
}

model Automation {
  id             String           @id @default(cuid())
  name           String
  description    String?
  status         AutomationStatus @default(ACTIVE)
  trigger        String           @default("manual")
  steps          Json?
  metricsSent    Int              @default(0)
  metricsClicked Int              @default(0)
  metricsRevenue Decimal          @default(0) @db.Decimal(12, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum AutomationStatus {
  ACTIVE
  PAUSED
  DRAFT
}

model GiftCard {
  id             String         @id @default(cuid())
  code           String         @unique
  customerName   String?
  customerEmail  String?
  initialValue   Decimal        @db.Decimal(10, 2)
  currentBalance Decimal        @db.Decimal(10, 2)
  status         GiftCardStatus @default(ACTIVE)
  note           String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([code])
  @@index([status])
}

enum GiftCardStatus {
  ACTIVE
  DEPLETED
  DISABLED
}

model Market {
  id         String       @id @default(cuid())
  name       String
  countries  Json
  currency   String       @default("INR")
  status     MarketStatus @default(ACTIVE)
  isPrimary  Boolean      @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum MarketStatus {
  ACTIVE
  INACTIVE
  DRAFT
}

model Catalog {
  id           String        @id @default(cuid())
  name         String
  region       String        @default("Global")
  status       CatalogStatus @default(ACTIVE)
  productCount Int           @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum CatalogStatus {
  ACTIVE
  INACTIVE
  DRAFT
}

model Company {
  id          String          @id @default(cuid())
  name        String
  type        String
  category    CompanyCategory @default(SUPPLIER)
  status      String          @default("Pending")
  contact     String?
  budgetTerms String?
  location    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
}

enum CompanyCategory {
  SUPPLIER
  SPONSOR
}

// ============ EMAIL LOG ============
// One row per outgoing email send (manual or automatic).
// Lets the admin see history, debug failures, and re-send.

model EmailLog {
  id            String          @id @default(cuid())
  // Which template was used (matches template file name without .html)
  templateKey   String
  // Resolved subject line at the time of send
  subject       String
  // The actual destination address (after EMAIL_TEST_MODE redirect, if any)
  toEmail       String
  // The original intended recipient (the customer's email — kept even if
  // test-mode redirected the send to the admin's inbox)
  intendedEmail String?
  // Optional links to the order / customer for filtering in the UI
  orderId       String?
  userId        String?

  status        EmailLogStatus  @default(PENDING)
  // Brevo / SMTP message-id once the send succeeds, for tracing
  messageId     String?
  // Error message if status = FAILED
  errorMessage  String?
  // Was this run in mock mode (no real SMTP creds set)?
  wasMocked     Boolean         @default(false)
  // Was the recipient redirected by EMAIL_TEST_MODE?
  wasTestRedirect Boolean       @default(false)

  // Snapshot of the template variables used — useful for re-sends + debugging
  variables     Json?

  // Who triggered the send (admin user id, "system" for auto-triggers, or "navya")
  triggeredBy   String?

  createdAt     DateTime        @default(now())
  sentAt        DateTime?

  @@index([orderId])
  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@index([templateKey])
}

enum EmailLogStatus {
  PENDING
  SENT
  FAILED
  MOCKED
}

// ============ NEWSLETTER SUBSCRIBERS ============
// Captures email signups from the storefront footer + checkout box. Each
// row represents one email address. Soft-deletion via `unsubscribedAt`
// so we have an audit trail and can re-subscribe cleanly.

model Subscriber {
  id              String    @id @default(cuid())
  email           String    @unique
  // Where the user signed up — "footer", "checkout", "drop-page", etc.
  // Used by the admin Subscribers list to show acquisition channel.
  source          String    @default("footer")
  // Optional link to a registered User (set if they were logged in
  // when they subscribed, otherwise null for anonymous email captures).
  userId          String?
  // ISO country code or city the subscribe came from (for analytics).
  country         String?
  // True once the user confirms via verification email — for now we
  // auto-confirm since DOI flows are out of scope.
  confirmed       Boolean   @default(true)
  // Soft-delete flag. Set when user unsubscribes (via unsubscribe link
  // in any campaign email). Keep the row so we don't re-add them by
  // accident.
  unsubscribedAt  DateTime?
  // Tags for segmentation (free-form, comma-separated). Future use.
  tags            String?

  subscribedAt    DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([email])
  @@index([source])
  @@index([unsubscribedAt])
}
